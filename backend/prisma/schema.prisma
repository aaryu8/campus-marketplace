// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ProductStatus {
  active
  sold
  // NOTE: "paused" removed — status is now only user-controlled (active/sold).
  // System moderation uses the separate ModerationStatus field.
}

enum ModerationStatus {
  clean
  warned      // reportWeight >= 3 — banner shown on listing, still visible
  suspended   // reportWeight >= 7 — hidden from marketplace, seller notified
}

enum ReportReason {
  spam
  price_scam
  duplicate
  inappropriate
  already_sold
  other
}

enum College {
  MAIT
  DTU
  IITD
  GGSIPU
  MSIT
  NSUT
  IIITD
  BVCOE
}

enum Branch {
  CSE
  IT
  ECE
  EEE
  ME
  CE
  BT
  CHE
  MAC
  NotSpecified
}

enum Category {
  general
  books
  electronics
  furniture
  clothes
  tickets
  sports
  transport
  hostel
}

enum Condition {
  new
  like_new
  good
  fair
  poor
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  salt        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  // Profile
  college     College
  branch      Branch?  @default(NotSpecified)
  year        Int?     @default(0)

  // Counters
  totalViews  Int      @default(0)

  // Trust & abuse system
  // trustScore: starts at 100, floor 0, cap 150
  // Used to weight reports: reportWeight += reporter.trustScore / 100
  trustScore  Int      @default(100)
  strikeCount Int      @default(0)

  // Relations
  products            Product[]
  sentMessages        Message[]
  buyerConversations  Conversation[]  @relation("Buyer")
  sellerConversations Conversation[]  @relation("Seller")
  reports             Report[]
  moderationEvents    ModerationEvent[]
}

model Product {
  id          String           @id @default(cuid())
  title       String
  price       Int
  description String           @db.Text
  category    Category
  condition   Condition
  image       String[]
  status      ProductStatus    @default(active)

  // ─── Moderation fields ────────────────────────────────────────
  moderationStatus ModerationStatus @default(clean)
  reportWeight     Float            @default(0)   // weighted sum, recalculated on each report
  flaggedAt        DateTime?                       // set when first leaving clean state
  lastReportAt     DateTime?                       // updated on every new report — drives time decay
  disputeUsed      Boolean          @default(false) // seller can dispute once per listing
  disputeAt        DateTime?                        // when dispute was filed (for 72h cooldown in Redis)
  // ──────────────────────────────────────────────────────────────

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt
  views       Int              @default(0)

  // Relations
  owner            User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId          String
  conversations    Conversation[]
  reports          Report[]
  moderationEvents ModerationEvent[]

  @@index([ownerId])
  @@index([category])
  @@index([createdAt])
  @@index([views])
  @@index([status])
  @@index([moderationStatus])
  @@index([lastReportAt])   // for time-decay cron query
}

// One row per report. Unique on (productId, reporterId) enforced at DB level.
model Report {
  id         String       @id @default(uuid())
  productId  String
  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason     ReportReason
  note       String?      @db.Text   // optional free-text from reporter
  createdAt  DateTime     @default(now())

  @@unique([productId, reporterId])   // one report per user per listing, enforced in DB
  @@index([productId])
  @@index([reporterId])
}

// Immutable audit log — every moderation state transition is written here.
// userId is null when the transition was triggered by the cron (system).
model ModerationEvent {
  id         String           @id @default(uuid())
  productId  String
  product    Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String?          // null = system / cron
  user       User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  fromStatus ModerationStatus
  toStatus   ModerationStatus
  reason     String           @db.Text
  createdAt  DateTime         @default(now())

  @@index([productId])
  @@index([createdAt])
}

model Conversation {
  id        String    @id @default(uuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User      @relation("Buyer", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId  String
  seller    User      @relation("Seller", fields: [sellerId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt

  @@unique([productId, buyerId, sellerId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([productId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  text           String       @db.Text
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

